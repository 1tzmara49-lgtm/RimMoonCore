<Defs>
  <!-- Sound defs -->

  <SoundDef>
    <defName>rm_hv_load</defName>
    <context>MapOnly</context>
    <maxSimultaneous>4</maxSimultaneous>
    <sustain>True</sustain>
    <priorityMode>PrioritizeNearest</priorityMode>
    <subSounds>
      <li>
        <muteWhenPaused>True</muteWhenPaused>
        <grains>
          <li Class="AudioGrain_Clip">
            <clipPath>Equipment/hv_rifle_charge</clipPath>
          </li>
        </grains>
        <volumeRange>30</volumeRange>
        <distRange>10~30</distRange>

        <sustainLoop>False</sustainLoop>
        <repeatMode>NeverTwice</repeatMode>
      </li>
    </subSounds>
  </SoundDef>

  <SoundDef>
    <defName>rm_hv_fire</defName>
    <context>MapOnly</context>
    <maxSimultaneous>4</maxSimultaneous>
    <priorityMode>PrioritizeNearest</priorityMode>
    <subSounds>
      <li>
        <muteWhenPaused>True</muteWhenPaused>
        <grains>
          <li Class="AudioGrain_Clip">
            <clipPath>Equipment/hv_rifle_shot</clipPath>
          </li>
        </grains>
        <volumeRange>30</volumeRange>
        <distRange>10~30</distRange>
      </li>
    </subSounds>
  </SoundDef>

  <SoundDef>
    <defName>rm_pulverisation_round_fire</defName>
    <context>MapOnly</context>
    <maxSimultaneous>4</maxSimultaneous>
    <priorityMode>PrioritizeNearest</priorityMode>
    <subSounds>
      <li>
        <muteWhenPaused>True</muteWhenPaused>
        <grains>
          <li Class="AudioGrain_Clip">
            <clipPath>Ability/pulverisation_shot</clipPath>
          </li>
        </grains>
        <volumeRange>30</volumeRange>
        <distRange>10~30</distRange>

      </li>
    </subSounds>
  </SoundDef>

  <SoundDef>
    <defName>rm_pulverisation_round_load</defName>
    <context>MapOnly</context>
    <maxSimultaneous>4</maxSimultaneous>
    <priorityMode>PrioritizeNearest</priorityMode>
    <sustain>True</sustain>
    <subSounds>
      <li>
        <muteWhenPaused>True</muteWhenPaused>
        <grains>
          <li Class="AudioGrain_Clip">
            <clipPath>Ability/pulverisation_load</clipPath>
          </li>
        </grains>
        <volumeRange>30</volumeRange>
        <distRange>10~30</distRange>
        
        <sustainLoop>False</sustainLoop>
        <repeatMode>NeverTwice</repeatMode>
      </li>
    </subSounds>
  </SoundDef>

  <!-- Ability def for the pulverisation round -->

  <AbilityDef>
    <defName>rm_pulverisation_round</defName>
    <label>pulverisation round</label>
    <description>Use a hemogenic chemical reaction to launch a bony spine at the target. The spine exits through the skin from an opening between the collarbones. Given the method of launch, it is surprisingly easy to aim.</description>
    <iconPath>UI/Abilities/PiercingSpine</iconPath>
    <displayOrder>200</displayOrder>
    <aiCanUse>true</aiCanUse>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>80.0</range>
      <warmupTime>10.0</warmupTime>
      <soundAiming>rm_pulverisation_round_load</soundAiming>
      <soundCast>rm_pulverisation_round_fire</soundCast>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>PiercingSpine</projectileDef>
      </li>
    </comps>
  </AbilityDef>
  
  <!-- The weapon itself -->

  <ThingDef ParentName="BaseHumanMakeableGun" Name="rm_hv_railgun">
    <defName>rm_hv_railgun</defName>
    <label>High velocity railgun</label>
    <description>A square barrelled rifle with a scope. Usually used by mid-level fixer offices to perform assassinations, but is useless against stronger opponents. Produced by Atelier Logic workshop, may fire empowered rounds by using their ammo.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/hv_railgun</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.3</drawSize>
    </graphicData>
    <soundInteract>Interact_Rifle</soundInteract>
    <weaponClasses>
      <li>LongShots</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <!-- <recipeMaker>
      <researchPrerequisite>PrecisionRifling</researchPrerequisite>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <displayPriority>425</displayPriority>
    </recipeMaker> -->
    <thingSetMakerTags>
      <li>RewardStandardQualitySuper</li>
    </thingSetMakerTags>
    <statBases>
      <!-- <WorkToMake>60000</WorkToMake> -->
      <Mass>4</Mass>
      <AccuracyTouch>0.20</AccuracyTouch>
      <AccuracyShort>0.50</AccuracyShort>
      <AccuracyMedium>0.8</AccuracyMedium>
      <AccuracyLong>0.85</AccuracyLong>
      <RangedWeapon_Cooldown>2.0</RangedWeapon_Cooldown>
    </statBases>
    <!-- <costList>
      <Steel>60</Steel>
      <ComponentIndustrial>8</ComponentIndustrial>
    </costList> -->
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_SniperRifle</defaultProjectile>
        <warmupTime>5.5</warmupTime>
        <range>44.9</range>
        <soundAiming>rm_hv_load</soundAiming>
        <soundCast>rm_hv_fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>3</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <weaponTags Inherit="False">
      <li>SniperRifle</li>
    </weaponTags>
    <comps Inherit="False">
      <li Class="CompProperties_EquippableAbilityReloadable">
        <abilityDef>rm_pulverisation_round</abilityDef>
        <maxCharges>1</maxCharges>
        <soundReload>Standard_Reload</soundReload>
        <chargeNoun>burner charge</chargeNoun>
        <ammoDef>rm_al_round</ammoDef>
        <baseReloadTicks>120</baseReloadTicks>
        <ammoCountToRefill>1</ammoCountToRefill>
        <replenishAfterCooldown>false</replenishAfterCooldown>
      </li>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Styleable"/>
      <li Class="CompProperties_Biocodable"/>
      <li>
        <compClass>CompQuality</compClass>
      </li>
    </comps>
  </ThingDef>
</Defs>